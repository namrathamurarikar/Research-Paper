class ErrorAnalyzer:
    """Comprehensive error analysis for classification results"""
    
    def __init__(self, predictions_file, language, model_name):
        """
        Args:
            predictions_file: CSV/Excel with columns: text, true_label, predicted_label, confidence
            language: Hindi/Tamil/Telugu
            model_name: name of the model
        """
        self.language = language
        self.model_name = model_name
        
        # Load predictions
        if predictions_file.endswith('.csv'):
            self.df = pd.read_csv(predictions_file)
        else:
            self.df = pd.read_excel(predictions_file)
        
        # Ensure required columns exist
        required_cols = ['text', 'true_label', 'predicted_label']
        if not all(col in self.df.columns for col in required_cols):
            # Try alternative column names
            column_mapping = {
                'label': 'true_label',
                'labels': 'true_label',
                'ground_truth': 'true_label',
                'prediction': 'predicted_label',
                'pred': 'predicted_label',
                'prompt': 'text',
                'sentence': 'text',
                'translated_text': 'text'
            }
            self.df.rename(columns=column_mapping, inplace=True)
        
        # Calculate errors
        self.df['is_correct'] = self.df['true_label'] == self.df['predicted_label']
        self.df['error_type'] = self.df.apply(self._classify_error, axis=1)
        
        # Statistics
        self.total_samples = len(self.df)
        self.correct = self.df['is_correct'].sum()
        self.errors = self.total_samples - self.correct
        self.accuracy = self.correct / self.total_samples
        
    def _classify_error(self, row):
        """Classify error type"""
        if row['is_correct']:
            return 'Correct'
        elif row['true_label'] == 1 and row['predicted_label'] == 0:
            return 'False Negative (FN)'
        elif row['true_label'] == 0 and row['predicted_label'] == 1:
            return 'False Positive (FP)'
        else:
            return 'Unknown'
    
    def generate_confusion_matrix(self):
        """Generate and save confusion matrix"""
        from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay
        
        cm = confusion_matrix(self.df['true_label'], self.df['predicted_label'])
        
        # Calculate metrics
        tn, fp, fn, tp = cm.ravel()
        precision = tp / (tp + fp) if (tp + fp) > 0 else 0
        recall = tp / (tp + fn) if (tp + fn) > 0 else 0
        f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0
        
        # Plot
        fig, ax = plt.subplots(figsize=(8, 6))
        disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=['Benign', 'Malicious'])
        disp.plot(ax=ax, cmap='Blues', values_format='d')
        
        # Get std dev if available
        std_info = ""
        if self.language in AVERAGE_METRICS:
            std_acc = AVERAGE_METRICS[self.language]['std_acc']
            std_f1 = AVERAGE_METRICS[self.language]['std_f1']
            std_info = f'\n(Avg ± Std: {self.accuracy*100:.2f}±{std_acc*100:.2f}%, F1: {f1*100:.2f}±{std_f1*100:.2f}%)'
        
        ax.set_title(f'{self.language.title()} - {self.model_name}\n'
                    f'Acc: {self.accuracy*100:.2f}%, Prec: {precision*100:.2f}%, '
                    f'Rec: {recall*100:.2f}%, F1: {f1*100:.2f}%{std_info}', 
                    fontsize=11, fontweight='bold')
        
        plt.tight_layout()
        plt.savefig(OUTPUT_DIR / f'confusion_matrix_{self.language}_{self.model_name}.png', 
                   dpi=300, bbox_inches='tight')
        plt.close()
        
        return {
            'tn': int(tn), 'fp': int(fp), 'fn': int(fn), 'tp': int(tp),
            'precision': precision, 'recall': recall, 'f1': f1, 'accuracy': self.accuracy
        }
    
    def analyze_error_patterns(self):
        """Analyze patterns in misclassified samples"""
        errors_df = self.df[~self.df['is_correct']].copy()
        
        if len(errors_df) == 0:
            return {"message": "No errors found - perfect classification!"}
        
        # Text length analysis
        errors_df['text_length'] = errors_df['text'].str.len()
        errors_df['word_count'] = errors_df['text'].str.split().str.len()
        
        # Group by error type
        fn_samples = errors_df[errors_df['error_type'] == 'False Negative (FN)']
        fp_samples = errors_df[errors_df['error_type'] == 'False Positive (FP)']
        
        analysis = {
            'total_errors': len(errors_df),
            'false_negatives': len(fn_samples),
            'false_positives': len(fp_samples),
            'fn_avg_length': fn_samples['text_length'].mean() if len(fn_samples) > 0 else 0,
            'fp_avg_length': fp_samples['text_length'].mean() if len(fp_samples) > 0 else 0,
            'fn_avg_words': fn_samples['word_count'].mean() if len(fn_samples) > 0 else 0,
            'fp_avg_words': fp_samples['word_count'].mean() if len(fp_samples) > 0 else 0,
        }
        
        # Categorize errors (heuristic-based)
        fn_samples['category'] = fn_samples['text'].apply(self._categorize_fn)
        fp_samples['category'] = fp_samples['text'].apply(self._categorize_fp)
        
        analysis['fn_categories'] = dict(fn_samples['category'].value_counts())
        analysis['fp_categories'] = dict(fp_samples['category'].value_counts())
        
        # Save error samples
        fn_samples[['text', 'category', 'text_length', 'word_count']].to_csv(
            OUTPUT_DIR / f'false_negatives_{self.language}_{self.model_name}.csv', 
            index=False
        )
        fp_samples[['text', 'category', 'text_length', 'word_count']].to_csv(
            OUTPUT_DIR / f'false_positives_{self.language}_{self.model_name}.csv', 
            index=False
        )
        
        return analysis
    
    def _categorize_fn(self, text):
        """Categorize false negative errors (malicious classified as benign)"""
        text_lower = text.lower()
        
        # Heuristic categorization based on common patterns
        if len(text.split()) > 50:
            return "Long/Complex Prompt"
        elif any(word in text_lower for word in ['please', 'kindly', 'help', 'can you']):
            return "Polite Phrasing"
        elif '?' in text and len(text.split()) < 15:
            return "Question Format"
        elif any(char.isdigit() for char in text):
            return "Contains Numbers/Code"
        else:
            return "Indirect/Subtle Malicious"
    
    def _categorize_fp(self, text):
        """Categorize false positive errors (benign classified as malicious)"""
        text_lower = text.lower()
        
        # Heuristic categorization
        if any(word in text_lower for word in ['how', 'what', 'why', 'when', 'where']):
            return "Legitimate Question"
        elif any(word in text_lower for word in ['explain', 'describe', 'tell me about']):
            return "Information Request"
        elif '!' in text or text.isupper():
            return "Imperative/Urgent Tone"
        elif any(word in text_lower for word in ['security', 'hack', 'attack', 'bypass']):
            return "Security-Related Topic"
        else:
            return "Ambiguous Phrasing"
    
    def visualize_error_distribution(self):
        """Create visualizations of error patterns"""
        errors_df = self.df[~self.df['is_correct']].copy()
        
        if len(errors_df) == 0:
            print("No errors to visualize")
            return
        
        fig, axes = plt.subplots(2, 2, figsize=(14, 10))
        
        # 1. Error type distribution
        error_counts = self.df['error_type'].value_counts()
        axes[0, 0].bar(error_counts.index, error_counts.values, color=['green', 'orange', 'red'])
        axes[0, 0].set_title('Error Type Distribution', fontweight='bold')
        axes[0, 0].set_ylabel('Count')
        axes[0, 0].tick_params(axis='x', rotation=45)
        
        # 2. Text length distribution by error type
        for error_type in ['False Negative (FN)', 'False Positive (FP)']:
            subset = errors_df[errors_df['error_type'] == error_type]
            if len(subset) > 0:
                axes[0, 1].hist(subset['text'].str.len(), bins=20, alpha=0.6, 
                              label=error_type)
        axes[0, 1].set_title('Text Length Distribution by Error Type', fontweight='bold')
        axes[0, 1].set_xlabel('Text Length (characters)')
        axes[0, 1].set_ylabel('Frequency')
        axes[0, 1].legend()
        
        # 3. FN categories
        fn_samples = errors_df[errors_df['error_type'] == 'False Negative (FN)']
        if len(fn_samples) > 0:
            fn_samples['category'] = fn_samples['text'].apply(self._categorize_fn)
            fn_cats = fn_samples['category'].value_counts()
            axes[1, 0].barh(fn_cats.index, fn_cats.values, color='salmon')
            axes[1, 0].set_title('False Negative Categories', fontweight='bold')
            axes[1, 0].set_xlabel('Count')
        
        # 4. FP categories
        fp_samples = errors_df[errors_df['error_type'] == 'False Positive (FP)']
        if len(fp_samples) > 0:
            fp_samples['category'] = fp_samples['text'].apply(self._categorize_fp)
            fp_cats = fp_samples['category'].value_counts()
            axes[1, 1].barh(fp_cats.index, fp_cats.values, color='skyblue')
            axes[1, 1].set_title('False Positive Categories', fontweight='bold')
            axes[1, 1].set_xlabel('Count')
        
        plt.suptitle(f'Error Analysis: {self.language.title()} - {self.model_name}', 
                    fontsize=14, fontweight='bold', y=1.00)
        plt.tight_layout()
        plt.savefig(OUTPUT_DIR / f'error_distribution_{self.language}_{self.model_name}.png', 
                   dpi=300, bbox_inches='tight')
        plt.close()
    
    def generate_report(self):
        """Generate comprehensive error analysis report"""
        print(f"\n{'='*60}")
        print(f"ERROR ANALYSIS REPORT: {self.language.title()} - {self.model_name}")
        print(f"{'='*60}\n")
        
        # Overall statistics
        print(f"Total Samples: {self.total_samples}")
        print(f"Correct Predictions: {self.correct} ({self.accuracy*100:.2f}%)")
        print(f"Total Errors: {self.errors} ({(1-self.accuracy)*100:.2f}%)\n")
        
        # Show average metrics context
        if self.language in AVERAGE_METRICS:
            avg = AVERAGE_METRICS[self.language]
            print(f"Context (Average Performance Across All Configs):")
            print(f"  Avg Accuracy: {avg['accuracy']*100:.2f}% (±{avg['std_acc']*100:.2f}%)")
            print(f"  Avg F1 Score: {avg['f1']*100:.2f}% (±{avg['std_f1']*100:.2f}%)\n")
        
        # Confusion matrix metrics
        cm_metrics = self.generate_confusion_matrix()
        print(f"Confusion Matrix Breakdown:")
        print(f"  True Negatives (TN):  {cm_metrics['tn']}")
        print(f"  False Positives (FP): {cm_metrics['fp']}")
        print(f"  False Negatives (FN): {cm_metrics['fn']}")
        print(f"  True Positives (TP):  {cm_metrics['tp']}\n")
        
        print(f"Performance Metrics:")
        print(f"  Precision: {cm_metrics['precision']*100:.2f}%")
        print(f"  Recall:    {cm_metrics['recall']*100:.2f}%")
        print(f"  F1-Score:  {cm_metrics['f1']*100:.2f}%\n")
        
        # Error patterns
        patterns = self.analyze_error_patterns()
        if 'message' not in patterns:
            print(f"Error Pattern Analysis:")
            print(f"  False Negatives: {patterns['false_negatives']}")
            print(f"    - Avg Length: {patterns['fn_avg_length']:.1f} chars")
            print(f"    - Avg Words:  {patterns['fn_avg_words']:.1f} words")
            print(f"    - Categories: {patterns['fn_categories']}\n")
            
            print(f"  False Positives: {patterns['false_positives']}")
            print(f"    - Avg Length: {patterns['fp_avg_length']:.1f} chars")
            print(f"    - Avg Words:  {patterns['fp_avg_words']:.1f} words")
            print(f"    - Categories: {patterns['fp_categories']}\n")
        
        # Visualizations
        self.visualize_error_distribution()
        
        # Save report to JSON (convert numpy types to Python types)
        def convert_numpy(obj):
            if isinstance(obj, dict):
                return {k: convert_numpy(v) for k, v in obj.items()}
            elif isinstance(obj, (np.integer, np.int64)):
                return int(obj)
            elif isinstance(obj, (np.floating, np.float64)):
                return float(obj)
            elif isinstance(obj, np.ndarray):
                return obj.tolist()
            else:
                return obj
        
        report = {
            'language': self.language,
            'model': self.model_name,
            'total_samples': int(self.total_samples),
            'accuracy': float(self.accuracy),
            'confusion_matrix': convert_numpy(cm_metrics),
            'error_patterns': convert_numpy(patterns) if 'message' not in patterns else {},
            'average_metrics': AVERAGE_METRICS.get(self.language, {})
        }
        
        with open(OUTPUT_DIR / f'error_report_{self.language}_{self.model_name}.json', 'w') as f:
            json.dump(report, f, indent=2)
        
        print(f"✅ Report saved to: {OUTPUT_DIR}")
        print(f"{'='*60}\n")
        
        return report


